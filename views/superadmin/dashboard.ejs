<%- include('../partials/header') %>

<div class="container-fluid p-0 d-flex flex-column flex-lg-row custom-dashboard-wrapper">
    <%- include('../partials/sidebarSuperAdmin') %>

    <main class="flex-grow-1 p-3 p-md-4 main-panel-content">
        <!-- Header Judul -->
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 pb-2 border-bottom gap-2">
            <div>
                <h4 class="fw-bold text-dark mb-1">Panel Kontrol Sistem</h4>
                <p class="text-muted small mb-0 body-text">Halo, <strong><%= user.nama %></strong>. Pengendali utama sistem infrastruktur.</p>
            </div>
            <span class="badge bg-light-blue text-cobalt border border-primary px-3 py-2 ui-label-caps fs-7">Akses: Superadmin</span>
        </div>

        <!-- Grid Statistik Asimetris / Tidak Sama Rata -->
        <div class="row g-3 mb-4">
            <div class="col-xl-3 col-sm-6">
                <div class="custom-card card-blue p-3 bg-white h-100">
                    <h6 class="text-muted mb-1 small ui-label-caps">Total Pelanggan</h6>
                    <h2 class="fw-bold text-dark mb-0">Mengecek...</h2>
                </div>
            </div>
            <div class="col-xl-3 col-sm-6">
                <div class="custom-card card-green p-3 bg-white h-100">
                    <h6 class="text-muted mb-1 small ui-label-caps">Total Admin/Pekerja</h6>
                    <h2 class="fw-bold text-dark mb-0">Mengecek...</h2>
                </div>
            </div>
            <div class="col-xl-3 col-sm-6">
                <div class="custom-card card-gold p-3 bg-white h-100">
                    <h6 class="text-muted mb-1 small ui-label-caps">Total Jenis Layanan</h6>
                    <h2 class="fw-bold text-dark mb-0">Mengecek...</h2>
                </div>
            </div>
            <div class="col-xl-3 col-sm-6">
                <div class="custom-card card-blue p-3 bg-cream h-100">
                    <h6 class="text-muted mb-1 small ui-label-caps text-cobalt">Total Pendapatan</h6>
                    <h2 class="fw-bold text-olive mb-0">Rp 0</h2>
                </div>
            </div>
        </div>

        <!-- Log Sistem Prominent Spanning Card -->
        <div class="custom-card card-blue p-4 bg-white">
            <h5 class="fw-bold text-cobalt mb-1"><i class="fa-solid fa-gears me-2 text-olive"></i>Log Aktivitas Sistem</h5>
            <div class="ornamental-divider my-2 ms-0"></div>
            <p class="text-muted small body-text mb-0">
                Semua sistem inti operasional FastClean berjalan dengan normal dan terhubung secara aman menuju database terenkripsi MySQL.
            </p>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>