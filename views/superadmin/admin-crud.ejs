<%- include('../partials/header') %>

<div class="container-fluid p-0 d-flex flex-column flex-lg-row custom-dashboard-wrapper">
    <%- include('../partials/sidebarSuperAdmin') %>

    <main class="flex-grow-1 p-3 p-md-4 main-panel-content">
        <h4 class="fw-bold text-dark mb-4">Kelola Data Admin / Pekerja Pembersih</h4>
        
        <!-- Form Register Pekerja -->
        <div class="card border-0 shadow-sm p-3 p-md-4 custom-card card-green mb-4">
            <h5 class="fw-bold text-olive mb-1">Daftarkan Admin Pekerja Baru</h5>
            <div class="ornamental-divider my-2 ms-0"></div>
            
            <form action="/superadmin/admin/create" method="POST" class="mt-3">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label ui-label-caps mb-1">Nama Lengkap</label>
                        <div class="input-group custom-input-group">
                            <input type="text" name="nama" class="form-control" placeholder="Nama Pekerja" required>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label ui-label-caps mb-1">Alamat Email</label>
                        <div class="input-group custom-input-group">
                            <input type="email" name="email" class="form-control" placeholder="nama@email.com" required>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label ui-label-caps mb-1">Password Baru</label>
                        <div class="input-group custom-input-group">
                            <input type="password" name="password" class="form-control" placeholder="••••••••" required>
                        </div>
                    </div>
                </div>
                <button type="submit" class="btn btn-success-custom mt-3 fw-bold text-white">Daftarkan Pekerja</button>
            </form>
        </div>

        <!-- Tabel Daftar Pekerja Aktif -->
        <div class="card border-0 shadow-sm p-3 p-md-4 custom-card card-blue">
            <h5 class="fw-bold text-cobalt mb-1">Daftar Admin / Pekerja Aktif</h5>
            <div class="ornamental-divider my-2 ms-0"></div>
            
            <div class="table-responsive custom-responsive-table mt-2">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr class="table-light border-bottom">
                            <th class="py-3 ui-label-caps text-cobalt">Nama Pekerja</th>
                            <th class="py-3 ui-label-caps text-cobalt">Email Akun</th>
                            <th class="py-3 ui-label-caps text-cobalt">Status</th>
                            <th class="py-3 ui-label-caps text-cobalt">Tanggal Bergabung</th>
                            <th class="py-3 ui-label-caps text-cobalt text-end">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(admins.length === 0) { %>
                            <tr><td colspan="5" class="text-center text-muted py-4 small body-text">Belum ada data unit admin pekerja terdaftar.</td></tr>
                        <% } %>
                        <% admins.forEach(admin => { %>
                            <tr class="border-bottom-0">
                                <td class="fw-bold text-dark"><%= admin.nama %></td>
                                <td><%= admin.email %></td>
                                <td>
                                    <span class="badge bg-light-green text-olive border border-success px-2 py-1.5 ui-label-caps">
                                        <%= admin.status %>
                                    </span>
                                </td>
                                <td><%= new Date(admin.created_at).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></td>
                                <td class="text-end">
                                    <a href="/superadmin/admin/delete/<%= admin.id %>" class="btn btn-secondary-custom py-1 px-3 btn-sm text-danger" onclick="return confirm('Hapus admin pekerja ini?')">Hapus</a>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>