<%- include('../partials/header') %>

<div class="container-fluid p-0 d-flex flex-column flex-lg-row custom-dashboard-wrapper">
    <!-- Komponen Sidebar Responsif -->
    <%- include('../partials/sidebarUser') %>

    <!-- Area Konten Utama Panel -->
    <main class="flex-grow-1 p-3 p-md-4 main-panel-content">
        
        <!-- Header Judul Halaman -->
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 pb-2 border-bottom gap-2">
            <div>
                <h4 class="fw-bold text-dark mb-1">Riwayat Pembelian</h4>
                <p class="text-muted small mb-0 body-text">Daftar seluruh layanan kebersihan Anda yang telah selesai dikerjakan.</p>
            </div>
            <span class="badge bg-light-green text-olive border border-success px-3 py-2 ui-label-caps"><i class="fa-solid fa-clock-rotate-left me-1"></i> Arsip Transaksi</span>
        </div>

        <!-- Tabel Konten / Card Area -->
        <div class="card border-0 shadow-sm p-3 p-md-4 custom-card card-blue">
            <% if (orders.length === 0) { %>
                <!-- Empty State (Icon-based composition sesuai design.md) -->
                <div class="text-center py-5 text-muted">
                    <div class="mb-3 text-cobalt">
                        <i class="fa-solid fa-folder-open fa-3x"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Belum Ada Riwayat</h5>
                    <p class="small body-text mb-4">Anda belum memiliki riwayat pesanan kebersihan yang selesai dikerjakan.</p>
                    <a href="/user/layanan" class="btn btn-primary-custom py-2 px-4 btn-sm">Pesan Layanan Sekarang</a>
                </div>
            <% } else { %>
                <!-- Responsive Table Wrapper -->
                <div class="table-responsive custom-responsive-table">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr class="table-light border-bottom">
                                <th class="py-3 ui-label-caps text-cobalt">Jenis Layanan</th>
                                <th class="py-3 ui-label-caps text-cobalt">Tanggal Pengerjaan</th>
                                <th class="py-3 ui-label-caps text-cobalt">Total Pembayaran</th>
                                <th class="py-3 ui-label-caps text-cobalt">Pekerja Pembersih</th>
                                <th class="py-3 ui-label-caps text-cobalt">Dokumentasi Unit</th> <!-- PERBAIKAN: Kolom Baru -->
                                <th class="py-3 ui-label-caps text-cobalt">Status Layanan</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% orders.forEach(order => { %>
                                <tr class="border-bottom-0">
                                    <td class="fw-bold text-secondary py-3"><%= order.nama_layanan %></td>
                                    <td class="py-3"><%= new Date(order.tanggal_booking).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></td>
                                    <td class="fw-bold text-olive py-3">Rp <%= Number(order.total_harga).toLocaleString('id-ID') %></td>
                                    <td class="py-3">
                                        <span class="fw-semibold text-dark"><%= order.nama_pekerja ? order.nama_pekerja : '-' %></span>
                                    </td>
                                    <!-- PERBAIKAN: Baris Aksi Menampilkan Foto Before & After -->
                                    <td class="py-3">
                                        <div class="d-flex gap-2">
                                            <% if(order.foto_before) { %>
                                                <a href="/uploads/<%= order.foto_before %>" target="_blank" class="btn btn-sm btn-outline-secondary py-1 px-2 border border-1 text-dark fs-7">
                                                    <i class="fa-solid fa-eye me-1"></i> Before
                                                </a>
                                            <% } %>
                                            <% if(order.foto_after) { %>
                                                <a href="/uploads/<%= order.foto_after %>" target="_blank" class="btn btn-sm btn-outline-primary py-1 px-2 border border-1 text-cobalt fs-7">
                                                    <i class="fa-solid fa-circle-check me-1"></i> After
                                                </a>
                                            <% } %>
                                            <% if(!order.foto_before && !order.foto_after) { %>
                                                <span class="text-muted small">-</span>
                                            <% } %>
                                        </div>
                                    </td>
                                    <td class="py-3">
                                        <span class="badge bg-light-green text-olive border border-success px-2 py-1.5 small ui-label-caps">
                                            <i class="fa-solid fa-circle-check me-1"></i> Selesai
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>