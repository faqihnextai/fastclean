<%- include('../partials/header') %>

<div class="container-fluid p-0 d-flex flex-column flex-lg-row custom-dashboard-wrapper">
    <!-- Komponen Sidebar Admin Responsif -->
    <%- include('../partials/sidebarAdmin') %>

    <!-- Area Konten Utama Panel -->
    <main class="flex-grow-1 p-3 p-md-4 main-panel-content">
        
        <!-- Header Judul Halaman -->
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center mb-4 pb-2 border-bottom gap-2">
            <div>
                <h4 class="fw-bold text-dark mb-1">Riwayat Pekerjaan Selesai</h4>
                <p class="text-muted small mb-0 body-text">Daftar rekaman seluruh berkas penugasan kebersihan yang telah berhasil Anda rampungkan.</p>
            </div>
            <span class="badge bg-light-green text-olive border border-success px-3 py-2 ui-label-caps"><i class="fa-solid fa-folder-closed me-1"></i> Arsip Admin</span>
        </div>

        <!-- Tabel Konten / Card Area -->
        <div class="card border-0 shadow-sm p-3 p-md-4 custom-card card-blue">
            <% if(completedOrders.length === 0) { %>
                <!-- Empty State Composition (Sesuai panduan design.md) -->
                <div class="text-center py-5 text-muted">
                    <div class="mb-3 text-cobalt">
                        <i class="fa-solid fa-clipboard-check fa-3x"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Belum Ada Riwayat</h5>
                    <p class="small body-text m-0">Anda belum memiliki catatan penyelesaian tugas kerja apa pun untuk saat ini.</p>
                </div>
            <% } else { %>
                <!-- Responsive Table Wrapper -->
                <div class="table-responsive custom-responsive-table">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr class="table-light border-bottom">
                                <th class="py-3 ui-label-caps text-cobalt">Jenis Layanan</th>
                                <th class="py-3 ui-label-caps text-cobalt">Nama Pelanggan</th>
                                <th class="py-3 ui-label-caps text-cobalt">Tanggal Pengerjaan</th>
                                <th class="py-3 ui-label-caps text-cobalt">Pendapatan Masuk</th>
                                <th class="py-3 ui-label-caps text-cobalt text-end">Status Kerja</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% completedOrders.forEach(order => { %>
                                <tr class="border-bottom-0">
                                    <td class="fw-bold text-secondary py-3"><%= order.nama_layanan %></td>
                                    <td class="py-3"><%= order.nama_pelanggan %></td>
                                    <td class="py-3"><%= new Date(order.tanggal_booking).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }) %></td>
                                    <td class="fw-bold text-olive py-3">Rp <%= Number(order.total_harga).toLocaleString('id-ID') %></td>
                                    <td class="text-end py-3">
                                        <span class="badge bg-light-green text-olive border border-success px-3 py-1.5 ui-label-caps">
                                            <i class="fa-solid fa-circle-check me-1"></i> Selesai
                                        </span>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </main>
</div>

<%- include('../partials/footer') %>