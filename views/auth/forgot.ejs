<%- include('../partials/header') %>

<div class="container d-flex align-items-center justify-content-center" style="min-height: 75vh; margin-top: 100px;">
    <div class="custom-card p-4 card-blue" style="width: 100%; max-width: 450px;">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-cobalt mb-1"><i class="fa-solid fa-broom me-2 text-olive"></i>FastClean</h2>
            <div class="ornamental-divider my-2"></div>
            <h4 class="fw-bold mt-2 text-dark fs-5">Lupa Password?</h4>
            <p class="text-muted small body-text">Masukkan email Anda yang terdaftar, kami akan mengirimkan instruksi pemulihan akun.</p>
        </div>
        
        <form action="/forgot" method="POST">
            <div class="mb-4">
                <label for="email" class="form-label ui-label-caps">Alamat Email Anda</label>
                <div class="input-group custom-input-group">
                    <span class="input-group-text"><i class="fa-solid fa-envelope text-muted"></i></span>
                    <input type="email" name="email" id="email" class="form-control" placeholder="nama@email.com" required>
                </div>
            </div>

            <button type="submit" class="btn btn-primary-custom w-100 py-2 mb-2 shadow-sm">Kirim Link Pemulihan</button>
            <a href="/login" class="btn btn-secondary-custom w-100 py-2 d-block text-center">Batal</a>
        </form>
    </div>
</div>

