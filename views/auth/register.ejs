<%- include('../partials/header') %>

<div class="container d-flex align-items-center justify-content-center" style="min-height: 85vh; margin-top: 100px;">
    <div class="custom-card p-4 card-green" style="width: 100%; max-width: 500px;">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-cobalt mb-1"><i class="fa-solid fa-broom me-2 text-olive"></i>FastClean</h2>
            <div class="ornamental-divider my-2"></div>
            <p class="text-muted body-text small">Buat akun pelanggan baru Anda</p>
        </div>
        
        <form action="/register" method="POST">
            <div class="mb-3">
                <label for="nama" class="form-label ui-label-caps">Nama Lengkap</label>
                <div class="input-group custom-input-group">
                    <span class="input-group-text"><i class="fa-solid fa-user text-muted"></i></span>
                    <input type="text" name="nama" id="nama" class="form-control" placeholder="Masukkan nama lengkap" required>
                </div>
            </div>

            <div class="mb-3">
                <label for="email" class="form-label ui-label-caps">Alamat Email</label>
                <div class="input-group custom-input-group">
                    <span class="input-group-text"><i class="fa-solid fa-envelope text-muted"></i></span>
                    <input type="email" name="email" id="email" class="form-control" placeholder="nama@email.com" required>
                </div>
            </div>

            <div class="mb-3">
                <label for="telepon" class="form-label ui-label-caps">Nomor Telepon / WhatsApp</label>
                <div class="input-group custom-input-group">
                    <span class="input-group-text"><i class="fa-solid fa-phone text-muted"></i></span>
                    <input type="tel" name="telepon" id="telepon" class="form-control" placeholder="08xxxxxxxxxx" required>
                </div>
            </div>
            
            <div class="mb-3">
                <label for="password" class="form-label ui-label-caps">Password</label>
                <div class="input-group custom-input-group">
                    <span class="input-group-text"><i class="fa-solid fa-lock text-muted"></i></span>
                    <input type="password" name="password" id="password" class="form-control" placeholder="Minimal 6 karakter" required>
                </div>
            </div>

            <button type="submit" class="btn btn-success-custom w-100 py-2 mt-3 text-white">Daftar Akun</button>
        </form>

        <div class="text-center mt-4">
            <p class="text-muted small body-text">Sudah memiliki akun? <a href="/login" class="text-decoration-none fw-bold text-cobalt">Masuk di sini</a></p>
        </div>
    </div>
</div>

