<%- include('../partials/header') %>

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh; margin-top: 100px;">
    <div class="custom-card p-4 card-blue" style="width: 100%; max-width: 450px;">
        <div class="text-center mb-4">
            <h2 class="fw-bold text-cobalt mb-1"><i class="fa-solid fa-broom me-2 text-olive"></i>FastClean</h2>
            <div class="ornamental-divider my-2"></div>
            <p class="text-muted body-text small">Silakan masuk ke akun Anda</p>
        </div>
        
        <form action="/login" method="POST">
            <div class="mb-3">
                <label for="email" class="form-label ui-label-caps">Alamat Email</label>
                <div class="input-group custom-input-group">
                    <span class="input-group-text"><i class="fa-solid fa-envelope text-muted"></i></span>
                    <input type="email" name="email" id="email" class="form-control" placeholder="nama@email.com" required>
                </div>
            </div>
            
            <div class="mb-3">
                <div class="d-flex justify-content-between">
                    <label for="password" class="form-label ui-label-caps">Password</label>
                    <a href="/forgot" class="text-decoration-none small text-olive fw-semibold">Lupa Password?</a>
                </div>
                <div class="input-group custom-input-group">
                    <span class="input-group-text"><i class="fa-solid fa-lock text-muted"></i></span>
                    <input type="password" name="password" id="password" class="form-control" placeholder="••••••••" required>
                </div>
            </div>

            <button type="submit" class="btn btn-primary-custom w-100 py-2 mt-3 shadow-sm">Masuk</button>
        </form>

        <div class="text-center mt-4">
            <p class="text-muted small body-text">Belum punya akun pelanggan? <a href="/register" class="text-decoration-none fw-bold text-cobalt">Daftar Sekarang</a></p>
            <hr class="my-3 opacity-25">
            <a href="/" class="btn btn-secondary-custom w-100 py-2 btn-sm fs-7"><i class="fa-solid fa-arrow-left me-1"></i> Kembali ke Beranda</a>
        </div>
    </div>
</div>

